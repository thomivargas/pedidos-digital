# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="sqlserver://HOST:1433;database=DB_NAME;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=false"
DB_HOST=HOST
DB_USER=USER
DB_PASSWORD=PASSWORD
DB_NAME=DB_NAME

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── JWT (generar con: openssl rand -hex 32) ─────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── BCRYPT ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS (URL del frontend, sin slash al final) ─────────────────────────────
CORS_ORIGIN=https://tu-dominio-frontend.vercel.app

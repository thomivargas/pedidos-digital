# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/pedidos_digital_db"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
DB_HOST=localhost
DB_PORT=3306
DB_USER=pedidos_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=pedidos_digital_db

# ─── JWT (generar con: openssl rand -hex 32) ─────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── BCRYPT ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS (URL del frontend, sin slash al final) ─────────────────────────────
CORS_ORIGIN=https://tu-dominio-frontend.vercel.app
